<Page x:Class="End_Project.Pages.view_page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:End_Project.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1000" d:DesignWidth="1600"
      Title="view_page">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="1000"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Hidden">
            <StackPanel>
                <ListView BorderBrush="White" x:Name="layout_grid" Margin="10,10,10,25" HorizontalContentAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0, 20" Width="400" Height="400" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="20" BorderBrush="LightGray" Background="White" BorderThickness="1">
                                <StackPanel Background="{x:Null}">
                                    <TextBox HorizontalContentAlignment="Center" Height="23" TextWrapping="Wrap" Text="{Binding tech_name, Mode=OneWay}" IsEnabled="False" FontSize="16" Margin="0,10,0,10" Background="{x:Null}" Foreground="Black" BorderBrush="{x:Null}"/>
                                    <Image Width="230" Height="230">
                                        <Image.Source>
                                            <Binding Path="tech_photo">
                                                <Binding.TargetNullValue>
                                                    <ImageSource>
                                                        /Images/icon.png
                                                    </ImageSource>
                                                </Binding.TargetNullValue>
                                            </Binding>
                                        </Image.Source>
                                    </Image>
                                    <TextBox HorizontalContentAlignment="Center" Height="23" TextWrapping="Wrap" Text="{Binding tech_price, Mode=OneWay}" IsEnabled="False" FontSize="16" Margin="10,0" Background="{x:Null}" Foreground="Black" BorderBrush="{x:Null}"/>
                                    <TextBox HorizontalContentAlignment="Center" Height="23" TextWrapping="Wrap"  Text="{Binding tech_type_name, Mode=OneWay}" IsEnabled="False" FontSize="16" Margin="10,0" Background="{x:Null}" Foreground="Black" BorderBrush="{x:Null}"/>
                                    <StackPanel Margin="0,20,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Button Name="button_edit" Style="{StaticResource  button_style}" Content="Edit" Margin="0,0,20,0" Background="Black" Foreground="White" Height="40" Width="120" Click="button_edit_Click"/>
                                        <Button Name="button_delete" Style="{StaticResource  button_style}" Content="Delete" Height="40" Background="Black" Foreground="White" Width="120" Click="button_delete_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                <Button x:Name="button_add" Style="{StaticResource  button_style}" HorizontalAlignment="Center" VerticalAlignment="Center" Content="Add" Background="Black" Foreground="White" Margin="0,0,20,0" Width="100" Click="button_add_Click"/>
                <Button Content="Exit" Style="{StaticResource  button_style}" x:Name="button_back" Background="Black" Foreground="White" Width="100" Click="button_back_Click"/>
            </StackPanel>
            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1">
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <Image Width="20" Margin="0,18,10,0" Height="20" Source="/Images/search.jpg"/>
                    <TextBox FontSize="20" Text="Search" BorderBrush="{x:Null}" Background="{x:Null}" VerticalContentAlignment="Center" x:Name="Search_text" Margin="0,20,0,0" Width="180" Height="30" TextChanged="Search_text_TextChanged" PreviewTextInput="Search_text_PreviewTextInput"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
