<Window x:Class="End_Project.Windows.edit_window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:End_Project.Windows"
        mc:Ignorable="d"
        Title="edit_window" Height="450" Width="700" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" Width="600">
            <StackPanel Margin="0,0,20,0" Orientation="Horizontal">
                <Border BorderBrush="LightGray" BorderThickness="2" CornerRadius="5,5,5,5" HorizontalAlignment="Center" Margin="5" Height="300" Width="300">
                    <Image  x:Name="IPicture" MaxHeight="200" MinHeight="150" Margin="5">
                        <Image.Source>
                            <Binding Path="tech_photo">
                                <Binding.TargetNullValue>
                                    <ImageSource>
                                        /Images/icon.png
                                    </ImageSource>
                                </Binding.TargetNullValue>
                            </Binding>
                        </Image.Source>
                    </Image>
                </Border>
            </StackPanel>
            <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                <WrapPanel HorizontalAlignment="Center"  Margin="0 0 0 5">
                    <Button x:Name="button_photo_add" Margin="0,0,0,10" Style="{StaticResource  button_style}" HorizontalAlignment="Center" VerticalAlignment="Center" Content="Add photo" Background="Black" Foreground="White" Width="100" Click="button_photo_add_Click"/>
                </WrapPanel>
                <WrapPanel Margin="0 0 0 5">
                    <TextBlock Text="name:" Width="60"/>
                    <TextBox x:Name="name_text"  Width="200" MaxLength="50" />
                </WrapPanel>
                <WrapPanel Margin="0 0 0 5">
                    <TextBlock Text="price:" Width="60"/>
                    <TextBox x:Name="price_text"  Width="200" MaxLength="50" PreviewTextInput="price_text_PreviewTextInput" />
                </WrapPanel>
                <WrapPanel Margin="0 0 0 5">
                    <TextBlock Text="type:" Width="60"/>
                    <ComboBox Width="100" x:Name="tech_type_combo_box"  Margin="0 0 15 0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding tech_type_name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </WrapPanel>

                <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button x:Name="button_add" Style="{StaticResource  button_style}" HorizontalAlignment="Center" VerticalAlignment="Center" Content="Edit entry" Background="Black" Foreground="White" Margin="0,0,20,0" Width="100" Click="button_add_Click"/>
                    <Button Content="Exit" Style="{StaticResource  button_style}" x:Name="button_back" Background="Black" Foreground="White" Width="100" Click="button_back_Click"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
